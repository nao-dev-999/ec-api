<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- プロファイル未指定時のフォールバック: 起動エラー等が握りつぶされないようにする -->
    <springProfile name="!local &amp; !test &amp; !dev &amp; !prod &amp; !staging">
        <appender name="FALLBACK_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%level] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="FALLBACK_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ローカル・テスト: 可読性重視のコンソール出力 -->
    <springProfile name="local,test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%level] [%X{requestId}] [userId:%X{userId}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- dev・本番・ステージング: JSON 構造化ログ -->
    <springProfile name="dev,prod,staging">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeContext>false</includeContext>
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</timestampPattern>
                <timeZone>${LOG_TIMEZONE:-Asia/Tokyo}</timeZone>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
        <logger name="org.hibernate.SQL" level="OFF"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="OFF"/>
    </springProfile>

</configuration>
