# プロジェクト基本情報
project     = "aws-test"
env         = "dev"
aws_region  = "ap-northeast-1"

# ネットワーク設定
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]
availability_zones   = ["ap-northeast-1a", "ap-northeast-1c"]

# RDS設定
rds_engine          = "postgres"
rds_engine_version  = "18.4"
rds_instance_class  = "db.t3.micro"
rds_database_name   = "awstest"
rds_master_username = "awstest"

# CodePipeline / GitHub
# AWSコンソール > CodePipeline > Settings > Connections で作成後にARNを貼る
codestar_connection_arn = "arn:aws:codestar-connections:ap-northeast-1:ACCOUNT_ID:connection/XXXXXXXX"
github_repository       = "your-org/ec-api"
github_branch           = "main"
